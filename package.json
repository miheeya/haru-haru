{
  "name": "haru-haru",
  "version": "0.4.0",
  "description": "Daily activity tracker with focus score and productivity insights",
  "main": "main.js",
  "author": "haru-haru",
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "electron-builder --win --dir",
    "build:installer": "electron-builder --win",
    "build:mac": "electron-builder --mac --dir"
  },
  "dependencies": {
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "vitest": "^4.1.2"
  },
  "build": {
    "directories": {
      "output": "release",
      "app": "."
    },
    "appId": "com.haruharu.app",
    "productName": "하루하루",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "하루하루",
      "language": 1042
    },
    "mac": {
      "target": "dir",
      "icon": "assets/icon.png",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": null,
      "entitlementsInherit": null
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*",
      "assets/**/*",
      "!test/**",
      "!vitest.config.js",
      "!**/*.test.js"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ]
  }
}
